# ── Secrets / personal config ─────────────────────────────────────────────────
# NEVER commit live config — it contains steam_api_key, Plex token, Proxmox token
Software/Desktop/config.yml

# ── Python build artifacts ────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd

# PyInstaller build output (regenerated by running pyinstaller)
Software/Desktop/build/
Software/Desktop/dist/

# Compiled installer (regenerated by Inno Setup)
Software/Desktop/installer_output/

# Debug render PNGs from development
Software/Desktop/debug_*.png

# ── Test sketches ────────────────────────────────────────────────────────────
Software/Test/

# ── OS / editor junk ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo

# ── SolidWorks backup files ───────────────────────────────────────────────────
CAD/*.sldasm~
CAD/*.sldprt~
